# Copy to .env and fill in before enabling the optional AI scientific-interpretation
# agent (see the "AI Scientific Agent" proposal in the architecture review).
# Never commit the real .env file.

# NCBI E-utilities (PubMed) — an API key raises the rate limit from 3 to 10 req/s.
# Register at https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=
NCBI_EMAIL=your_email@example.com

# Semantic Scholar — optional, raises rate limits.
# Register at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex — no key required, but a "polite pool" email is recommended.
OPENALEX_EMAIL=your_email@example.com

# LLM provider for the AI Interpretation feature (app.py sidebar). Either one
# is enough — the sidebar lets you pick Claude or ChatGPT per session, and
# these env vars only serve as an optional prefill for that field (you can
# also just paste a key directly in the UI without ever setting these).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
